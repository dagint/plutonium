# paperless/.env — copy to .env and fill in values; never commit .env

BIND_ADDR=192.168.x.x
TS_AUTHKEY=tskey-client-xxxxx

# Generate once before first run — changing this invalidates all sessions
PAPERLESS_SECRET_KEY=

PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=    # 32+ char random

PAPERLESS_URL=https://paperless.your-tailnet.ts.net
PAPERLESS_ALLOWED_HOSTS=paperless.your-tailnet.ts.net,192.168.x.x

POSTGRES_PASSWORD=           # 32+ char random

TIMEZONE=America/Chicago
