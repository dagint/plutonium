# ============================================================
# plutonium/.env  —  single env file for all services
# Copy this to .env, fill in all values, never commit .env
# Used by all docker compose stacks via --env-file ~/plutonium/.env
# ============================================================

# ============================================================
# Shared
# ============================================================

# LAN IP of this host — used to bind service ports for local access
# UFW restricts these ports to the LAN subnet only
BIND_ADDR=192.168.x.x

# Tailscale auth key — reusable key from:
# https://login.tailscale.com/admin/settings/keys
# Rotate after initial deployment; update here and restart sidecars
TS_AUTHKEY=tskey-client-xxxxx

# Timezone — used by n8n and Paperless
TIMEZONE=America/Chicago

# ============================================================
# Monitoring — Grafana
# ============================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=           # 32+ char random string
GRAFANA_ROOT_URL=https://grafana.your-tailnet.ts.net

# ============================================================
# Monitoring — UniFi Poller
# Create a LOCAL read-only account in UniFi controller:
# Settings → Admins → Add Admin → Role: View Only → Local Access Only
# ============================================================

UNIFI_URL=https://10.80.1.1
UNIFI_USER=unpoller               # dedicated read-only account
UNIFI_PASS=                       # that account's password

# UniFi Protect (optional)
UNIFI_PROTECT_URL=https://10.80.21.97
UNIFI_PROTECT_USER=unpoller
UNIFI_PROTECT_PASS=

# ============================================================
# Monitoring — Tesla Powerwall
# ============================================================

PW_HOST=                          # gateway LAN IP
PW_PASSWORD=                      # Powerwall gateway password
PW_EMAIL=                         # Tesla account email

# ============================================================
# Monitoring — Tempest WeatherFlow
# ============================================================

TEMPEST_STATION_ID=
TEMPEST_API_TOKEN=                # from weatherflow developer portal

# ============================================================
# Monitoring — Cloudflare (optional)
# ============================================================

# CLOUDFLARE_API_TOKEN=

# ============================================================
# n8n
# ============================================================

# Generate once before first run — changing this breaks all stored credentials
N8N_ENCRYPTION_KEY=               # 32+ char random, set once, never change

N8N_HOST=n8n.your-tailnet.ts.net
WEBHOOK_URL=https://n8n.your-tailnet.ts.net/

N8N_ADMIN_EMAIL=
N8N_ADMIN_PASSWORD=               # 32+ char random

# ============================================================
# Paperless-ngx
# ============================================================

# Generate once before first run — changing this invalidates all sessions
PAPERLESS_SECRET_KEY=             # 50+ char random, set once, never change

PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=         # 32+ char random

PAPERLESS_URL=https://paperless.your-tailnet.ts.net
PAPERLESS_ALLOWED_HOSTS=paperless.your-tailnet.ts.net,192.168.x.x

POSTGRES_PASSWORD=                # 32+ char random
