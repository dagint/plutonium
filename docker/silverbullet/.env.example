# Networking — host LAN IP to bind local ports on
BIND_ADDR=192.168.x.x

# Tailscale — reusable auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-client-xxxxx

# SilverBullet authentication — format: username:password (32+ char random password)
# Generate: openssl rand -base64 24
# Set BEFORE first run — this controls access to your entire note space
SB_USER=admin:changeme
